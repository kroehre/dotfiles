mux() {
  local name cols claude=0 kill=0 dir=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -c) claude=1 ;;
      -K) kill=1 ;;
      *) dir="$1" ;;
    esac
    shift
  done

  if [ -n "$dir" ]; then
    cd "$dir"
  fi

  name="$(basename "$PWD" | sed -e 's/\./-/g')"

  if (( kill )); then
    tmux -L mux kill-session -t "$name" 2>/dev/null
    tmux kill-session -t "$name" 2>/dev/null
    return
  fi

  cols="$(tput cols)"

  if (( claude )); then
    # Create inner project session on default server
    if ! tmux has-session -t "$name" 2>/dev/null; then
      tmux new-session -d -n tests -s "$name" -x${cols:-150} -y50
      tmux new-window -a -d -n server -t "$name:0"
    fi

    # Create outer container on separate socket
    if ! tmux -L mux has-session -t "$name" 2>/dev/null; then
      local prompt_file="$HOME/.claude/tmux-prompt-$name.md"
      sed "s/\$SESSION/$name/g" "$DOTHOME/claude/tmux-pairing.md" > "$prompt_file"
      tmux -L mux -f "$DOTHOME/tmux/claude-container.conf" \
        new-session -d -s "$name" -x${cols:-150} -y50 \
        "while true; do claude --allowedTools 'mcp__tmux__*' 'Bash(tmux:*)' --append-system-prompt \"\$(cat '$prompt_file')\"; echo; echo 'Claude exited. Press Enter to restart or Ctrl-C to quit.'; read || break; done"
      tmux -L mux split-window -t "$name" -h \
        "TMUX= tmux attach-session -t '$name'"
      tmux -L mux select-pane -t "$name:0.0"
    fi

    tmux -L mux attach-session -t "$name"
  else
    if ! tmux has-session -t "$name" 2>/dev/null; then
      tmux new-session -d -n code -s "$name" -x${cols:-150} -y50 && \
        tmux new-window -a -d -n tests -t "$name:0" \; \
        new-window -a -d -n server -t "$name:1" \; \
        select-layout -t "$name" main-vertical &>/dev/null
    fi

    tmux attach-session -t "$name"
  fi
}
