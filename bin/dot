#!/bin/sh
#
# dot
#
# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.
export DOTHOME=$HOME/.dotfiles

DISTRO=$(uname)
case $DISTRO in
  'Linux')
    sudo apt-get update
    sudo apt-get -y -q upgrade
    ;;
  'Darwin')
    # Set macOS defaults
    sh $DOTHOME/macos/set-defaults.sh
    # Install/upgrade homebrew packages
    sh $DOTHOME/homebrew/install.sh 2>&1
    # Install ruby tooling (chruby, gem_home, ruby-install)
    sh $DOTHOME/ruby/install.sh 2>&1
    # Install Ghostty config
    sh $DOTHOME/ghostty/install.sh 2>&1
    # Install Claude Code and merge settings
    sh $DOTHOME/claude/install.sh 2>&1
    ;;
  *)
    echo "Good luck with that"
    ;;
esac

# Install neovim config and plugins
$DOTHOME/nvim/install.sh 2>&1
